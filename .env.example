# CHOps environment configuration (example)
#
# Copy this file to .env and fill in real values. The variables below are the
# ones the server actually reads (see src/backend/utils/env.js). Only the items
# marked REQUIRED must be set for the server to start; everything else has a
# sensible default.

# --- Super admin seeding (REQUIRED) ---------------------------------------
# At least the first super admin (SUPER_ADMIN_1 + SUPER_ADMIN_1_PASSWORD) must
# be set. You can define up to three numbered super admins. These accounts are
# created on first startup and are used for initial setup and emergency login.
SUPER_ADMIN_1=admin
SUPER_ADMIN_1_PASSWORD=change_me_to_a_strong_password
SUPER_ADMIN_1_EMAIL=change_with_your_mailID
# SUPER_ADMIN_2=admin2
# SUPER_ADMIN_2_PASSWORD=another_strong_password
# SUPER_ADMIN_2_EMAIL=superadmin@mailid
# SUPER_ADMIN_3=admin3
# SUPER_ADMIN_3_PASSWORD=yet_another_strong_password
# SUPER_ADMIN_3_EMAIL=superadmin@mailid

# Legacy single-admin format (still accepted if the numbered vars are absent):
# SUPER_ADMIN=admin
# SUPER_ADMIN_PASSWORD=change_me
# SUPER_ADMIN_EMAIL=change_with_your_mailID

# --- Session / auth (REQUIRED) --------------------------------------------
# Secret used to sign sessions and to derive encryption keys for stored
# credentials. Use a long, random value (32+ characters). cmd - openssl rand -hex 32

SESSION_SECRET=replace_with_a_long_random_secret_32_chars_min

# --- Server -----------------------------------------------------------------
# Port the backend listens on (default 3000) and the runtime environment.
PORT=3000
NODE_ENV=development

# Set to true to disable the .env super-admin login fallback once real users
# exist in the app database. Leave unset (or false) during initial setup.
DISABLE_ENV_LOGIN=true

# --- Email (SMTP) for alert notifications (optional) -----------------------
# Required only if you want CHOps to send alert emails. Without these, email
# channels simply will not send.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CHOps <noreply@chops>

# --- Build / version metadata (optional) -----------------------------------
# Populated by the build pipeline; usually left blank in local development.
CLICKHOUSEVERSION=
MAJOR=
MINOR=
PATCH=
DISPLAY=
VERSION=
CODENAME=


# Frontend Env key-values
# TLS REJECT_UNAUTHORIZED = '0';
VITE_TLS_REJECT_UNAUTHORIZED='0'


# Chat history key for localstorage 
VITE_QURIOZ_KEY=quriozchatstorage


#QUERY GENERATION chat URL for AI URL server
VITE_QUERYGENERATIONURL=http://localhost:3005

#SELECTAIIDS for localstorage
VITE_SELECTEDAID_DBS=aiselectedid


# Mail to login page navigating URl
FRONTEND_LINK=http://localhost:5173