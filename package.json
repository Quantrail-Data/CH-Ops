{
  "name": "chops",
  "version": "26.3-0.1.6",
  "description": "CHOps - ClickHouse® Administration Dashboard",
  "author": "Quantrail™ Data Private Limited",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "bun run gen:version && bun --watch src/backend/server.js",
    "dev:frontend": "vite",
    "build": "bun run gen:version && vite build",
    "embed": "bun scripts/embed-static.js",
    "gen:search-headers": "node scripts/build-search-headers.mjs",
    "gen:version": "node scripts/generate-version.mjs",
    "build:binary": "bun run build && bun run embed && bun build src/backend/server.js --compile --outfile chops",
    "build:binary:linux": "bun run build && bun run embed && bun build src/backend/server.js --compile --target=bun-linux-x64 --outfile chops-linux-x64",
    "build:binary:mac": "bun run build && bun run embed && bun build src/backend/server.js --compile --target=bun-darwin-arm64 --outfile chops-darwin-arm64",
    "build:binary:windows": "bun run build && bun run embed && bun build src/backend/server.js --compile --target=bun-windows-x64 --outfile chops-windows-x64.exe",
    "build:standalone:mac": "bun run build && bun run embed && bun build src/backend/server.js --compile --env=inline --target=bun-darwin-arm64 --outfile chops-darwin-arm64",
    "build:standalone:linux": "bun run build && bun run embed && bun build src/backend/server.js --compile --env=inline --target=bun-linux-x64 --outfile chops-linux-x64",
    "build:standalone:windows": "bun run build && bun run embed && bun build src/backend/server.js --compile --env=inline --target=bun-windows-x64 --outfile chops-windows-x64.exe",
    "test": "bun run test:backend && vitest run tests/frontend",
    "test:backend": "bun test tests/backend",
    "test:coverage": "bun run test:backend:coverage && bun run test:frontend:coverage",
    "test:backend:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage/backend tests/backend",
    "test:frontend:coverage": "vitest run tests/frontend --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "check:sensitive-logging": "node scripts/check-sensitive-logging.mjs",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun src/backend/db/migrate.js",
    "db:backup": "bun src/backend/db/backup.js",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@clickhouse/client": "^1.21.0",
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource/b612": "^5.2.7",
    "@fontsource/red-hat-mono": "^5.2.8",
    "@google/genai": "^2.11.0",
    "@mistralai/mistralai": "^2.4.1",
    "@opentelemetry/api": "^1.9.1",
    "@react-oauth/google": "^0.13.5",
    "@tabler/icons-webfont": "^3.44.0",
    "@xenova/transformers": "^2.17.2",
    "@xyflow/react": "^12.11.0",
    "axios": "^1.18.0",
    "drizzle-orm": ">=0.45.2",
    "echarts": "^6.1.0",
    "express": "5.1.0",
    "farmhash": "^5.0.1",
    "fuse.js": "^7.4.2",
    "js-yaml": "^4.3.0",
    "jsonwebtoken": "9.0.2",
    "motion": "^12.39.0",
    "onnxruntime-web": "1.14.0",
    "openai": "^6.47.0",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-otp-input": "^3.1.1",
    "react-router-dom": "^7.18.1",
    "sql-formatter": "^15.8.2",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/bun": "latest",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.5",
    "@vitejs/plugin-react": "4.4.1",
    "@vitest/coverage-istanbul": "3.2.1",
    "concurrently": "9.1.0",
    "drizzle-kit": "^1.0.0-rc.4-ca0f029",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "jsdom": "25.0.1",
    "vite": ">=6.4.3",
    "vitest": ">=3.2.6"
  },
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  },
  "patchedDependencies": {
    "@xenova/transformers@2.17.2": "patches/@xenova%2Ftransformers@2.17.2.patch"
  }
}